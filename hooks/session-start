#!/usr/bin/env bash
# Session start hook -- injects using-necturalabs skill + checks for updates

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
SKILL_FILE="$PLUGIN_ROOT/skills/using-necturalabs/SKILL.md"

if [ ! -f "$SKILL_FILE" ]; then
    exit 0
fi

# Check for updates (non-blocking, silent on failure)
UPDATE_MSG=""
if command -v git &>/dev/null && [ -d "$PLUGIN_ROOT/.git" ]; then
    LOCAL_SHA=$(git -C "$PLUGIN_ROOT" rev-parse HEAD 2>/dev/null || echo "")
    REMOTE_SHA=$(git -C "$PLUGIN_ROOT" ls-remote origin HEAD 2>/dev/null | cut -f1 || echo "")
    if [ -n "$LOCAL_SHA" ] && [ -n "$REMOTE_SHA" ] && [ "$LOCAL_SHA" != "$REMOTE_SHA" ]; then
        UPDATE_MSG="\\n\\n[NecturaLabs] Update available! Run: /plugin marketplace update necturalabs"
    fi
fi

SKILL_CONTENT=$(cat "$SKILL_FILE" 2>&1 || echo "Error reading using-necturalabs skill")

# JSON-escape the content using bash parameter substitution
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

ESCAPED=$(escape_for_json "$SKILL_CONTENT")
UPDATE_ESCAPED=$(escape_for_json "$UPDATE_MSG")
SESSION_CONTEXT="${ESCAPED}${UPDATE_ESCAPED}"

# Output context injection as JSON
# Cursor expects additional_context; Claude Code expects hookSpecificOutput.additionalContext
# Only emit the field for the current platform to avoid double injection
if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
    printf '{\n  "additional_context": "%s"\n}\n' "$SESSION_CONTEXT"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
    printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$SESSION_CONTEXT"
else
    printf '{\n  "additional_context": "%s"\n}\n' "$SESSION_CONTEXT"
fi

exit 0
