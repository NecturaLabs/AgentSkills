# Auto detect text files and normalize line endings
* text=auto

# Markdown
*.md text eol=lf

# Shell scripts
*.sh text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# JSON/YAML
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# JavaScript/TypeScript
*.js text eol=lf
*.ts text eol=lf

# Python
*.py text eol=lf
